# Local development only. Copy this file to .env and fill in local values.

# Required for automated topic search.
TAVILY_API_KEY=
OPENAI_API_KEY=

# Optional. Defaults to https://api.tavily.com/search.
TAVILY_ENDPOINT=

# Optional. Defaults to gpt-5-nano.
OPENAI_MODEL=
OPENAI_ENDPOINT=

# Optional local defaults.
ADDR=:8080
DB_PATH=data/dailydocs.sqlite
